# GitHub MCP Server - Environment Variables Example
#
# Copy this file to .env and fill in your actual values
# The .env file is gitignored for security

# GitHub Personal Access Token
# Required permissions: repo, security_events (optional but recommended)
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Optional: Specify default repository (for testing)
# TEST_REPO_OWNER=your_username
# TEST_REPO_NAME=your_repo_name
